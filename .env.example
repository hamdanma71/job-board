# إعدادات قاعدة البيانات (PostgreSQL)
# مثال لرابط الاتصال من Vercel Postgres أو Supabase:
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# مفتاح التشفير لجلسات المستخدمين (NextAuth)
# يجب أن تقوم بتوليد مفتاح عشوائي طويل ووضعه هنا في بيئة الإنتاج:
# يمكن توليده عبر الأمر: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-for-production"

# رابط الموقع الرئيسي (ضروري لـ NextAuth)
# في بيئة التطوير: http://localhost:3000
# في بيئة الإنتاج: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# مفتاح OpenAI API لخدمات الذكاء الاصطناعي (تحليل السير الذاتية)
OPENAI_API_KEY="sk-your-openai-api-key-here"
